"""
Пользовательские команды: /start, /help, /sub, /settings
"""

import logging
from datetime import datetime

from aiogram import Router, F
from aiogram.filters import Command
from aiogram.types import Message, CallbackQuery, InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.fsm.context import FSMContext

from database.db import upsert_user, is_subscribed, get_subscription, get_user_settings, toggle_user_setting
from config import ADMIN_IDS, BOT_NAME

router = Router()
logger = logging.getLogger(__name__)


# ── /start ───────────────────────────────────────────────────

@router.message(Command("start"))
async def cmd_start(msg: Message, state: FSMContext):
    await state.clear()
    u = msg.from_user
    await upsert_user(u.id, u.username, u.first_name)

    subscribed = await is_subscribed(u.id)
    is_admin = u.id in ADMIN_IDS

    if is_admin:
        status = "👑 Администратор"
    elif subscribed:
        sub = await get_subscription(u.id)
        exp = datetime.strptime(sub["expires_at"], "%Y-%m-%d %H:%M:%S")
        days_left = (exp - datetime.now()).days
        status = f"✅ Подписка активна (осталось {days_left} дн.)"
    else:
        status = "❌ Нет подписки"

    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="⚙️ Настройки уведомлений", callback_data="user:settings")],
        [InlineKeyboardButton(text="📋 Моя подписка", callback_data="user:sub")],
        [InlineKeyboardButton(text="❓ Как пользоваться", callback_data="user:help")],
    ])

    await msg.answer(
        f"👁 <b>ShadowWatch</b>\n\n"
        f"Привет, {u.first_name}!\n\n"
        f"Статус: {status}\n\n"
        f"Я слежу за сообщениями в чатах и уведомляю тебя о:\n"
        f"• 🗑 Удалённых сообщениях\n"
        f"• ✏️ Отредактированных сообщениях\n"
        f"• 💣 Самоуничтожающихся медиа\n\n"
        f"<i>Добавь меня в чат через «Автоматизация» → я начну мониторинг</i>",
        reply_markup=kb
    )


# ── /help ────────────────────────────────────────────────────

@router.message(Command("help"))
async def cmd_help(msg: Message):
    await msg.answer(help_text(), reply_markup=main_back_kb())


@router.callback_query(F.data == "user:help")
async def cb_help(call: CallbackQuery):
    await call.message.edit_text(help_text(), reply_markup=main_back_kb())
    await call.answer()


def help_text() -> str:
    return (
        "❓ <b>Как пользоваться ShadowWatch</b>\n\n"
        "<b>1. Добавить бота в чат:</b>\n"
        "Открой нужный чат → Настройки → Автоматизация чатов → добавь @shadowwatchbot\n\n"
        "<b>2. Что отслеживается:</b>\n"
        "• 🗑 Удалённые сообщения — бот сохраняет текст/медиа и присылает тебе копию\n"
        "• ✏️ Отредактированные сообщения — бот показывает «до» и «после»\n"
        "• 💣 Самоуничтожающиеся фото/видео — бот успевает скачать и переслать\n\n"
        "<b>3. Команды:</b>\n"
        "/start — главное меню\n"
        "/sub — статус подписки\n"
        "/settings — настройки уведомлений\n\n"
        "<b>4. Важно:</b>\n"
        "Бот видит только те чаты, куда его добавили. В личке 1-на-1 не работает — "
        "нужна группа или бот-автоматизация."
    )


# ── /sub ─────────────────────────────────────────────────────

@router.message(Command("sub"))
async def cmd_sub(msg: Message):
    await show_sub(msg.from_user.id, msg)


@router.callback_query(F.data == "user:sub")
async def cb_sub(call: CallbackQuery):
    await show_sub(call.from_user.id, call.message, edit=True)
    await call.answer()


async def show_sub(user_id: int, target, edit=False):
    if user_id in ADMIN_IDS:
        text = "👑 <b>Администратор</b> — безлимитный доступ"
    else:
        sub = await get_subscription(user_id)
        if not sub:
            text = (
                "❌ <b>Подписка не активна</b>\n\n"
                "Обратись к администратору для получения доступа."
            )
        else:
            exp = datetime.strptime(sub["expires_at"], "%Y-%m-%d %H:%M:%S")
            now = datetime.now()
            if exp > now:
                days_left = (exp - now).days
                text = (
                    f"✅ <b>Подписка активна</b>\n\n"
                    f"📅 Истекает: <b>{exp.strftime('%d.%m.%Y %H:%M')}</b>\n"
                    f"⏳ Осталось: <b>{days_left} дн.</b>"
                )
            else:
                text = (
                    "⏰ <b>Подписка истекла</b>\n\n"
                    f"Дата истечения: {exp.strftime('%d.%m.%Y %H:%M')}\n"
                    "Обратись к администратору для продления."
                )

    kb = main_back_kb()
    if edit:
        await target.edit_text(text, reply_markup=kb)
    else:
        await target.answer(text, reply_markup=kb)


# ── /settings ────────────────────────────────────────────────

@router.message(Command("settings"))
async def cmd_settings(msg: Message):
    await show_settings(msg.from_user.id, msg)


@router.callback_query(F.data == "user:settings")
async def cb_settings(call: CallbackQuery):
    await show_settings(call.from_user.id, call.message, edit=True)
    await call.answer()


async def show_settings(user_id: int, target, edit=False):
    s = await get_user_settings(user_id)

    def ico(val): return "🟢" if val else "🔴"

    text = (
        "⚙️ <b>Настройки уведомлений</b>\n\n"
        f"{ico(s['notify_delete'])} Удалённые сообщения\n"
        f"{ico(s['notify_edit'])} Редактированные сообщения\n"
        f"{ico(s['notify_self_destruct'])} Самоуничтожающиеся медиа"
    )

    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(
            text=f"{ico(s['notify_delete'])} Удалённые",
            callback_data="toggle:notify_delete"
        )],
        [InlineKeyboardButton(
            text=f"{ico(s['notify_edit'])} Редактирования",
            callback_data="toggle:notify_edit"
        )],
        [InlineKeyboardButton(
            text=f"{ico(s['notify_self_destruct'])} Самоуничтожение",
            callback_data="toggle:notify_self_destruct"
        )],
        [InlineKeyboardButton(text="◀️ Назад", callback_data="user:back")],
    ])

    if edit:
        await target.edit_text(text, reply_markup=kb)
    else:
        await target.answer(text, reply_markup=kb)


@router.callback_query(F.data.startswith("toggle:"))
async def cb_toggle(call: CallbackQuery):
    subscribed = await is_subscribed(call.from_user.id) or call.from_user.id in ADMIN_IDS
    if not subscribed:
        await call.answer("❌ Нужна активная подписка!", show_alert=True)
        return

    field = call.data.split(":", 1)[1]
    await toggle_user_setting(call.from_user.id, field)
    await show_settings(call.from_user.id, call.message, edit=True)
    await call.answer("Настройка изменена ✅")


# ── Назад в главное меню ─────────────────────────────────────

@router.callback_query(F.data == "user:back")
async def cb_back(call: CallbackQuery, state: FSMContext):
    await state.clear()
    u = call.from_user
    await cmd_start.__wrapped__(call.message, state) if hasattr(cmd_start, "__wrapped__") else None

    # Простой редирект
    subscribed = await is_subscribed(u.id) or u.id in ADMIN_IDS
    status = "✅ Подписка активна" if subscribed else "❌ Нет подписки"
    if u.id in ADMIN_IDS:
        status = "👑 Администратор"

    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="⚙️ Настройки уведомлений", callback_data="user:settings")],
        [InlineKeyboardButton(text="📋 Моя подписка", callback_data="user:sub")],
        [InlineKeyboardButton(text="❓ Как пользоваться", callback_data="user:help")],
    ])
    await call.message.edit_text(
        f"👁 <b>ShadowWatch</b>\n\nСтатус: {status}",
        reply_markup=kb
    )
    await call.answer()


def main_back_kb():
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="◀️ Главное меню", callback_data="user:back")]
    ])
